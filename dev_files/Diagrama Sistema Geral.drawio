        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% Definindo os estilos\n    classDef inicioFim fill:#111,stroke:#fff,stroke-width:2px,color:#fff\n    classDef estado fill:#2B3A42,stroke:#fff,stroke-width:2px,color:#fff\n    classDef acao fill:#4A5D23,stroke:#fff,stroke-width:2px,color:#fff\n    classDef decisao fill:#DAA520,stroke:#fff,stroke-width:2px,color:#111\n\n    %% Textos envolvidos em aspas e sem parênteses para evitar erros de Parse\n    A([\&quot;Início do Jogo\&quot;]) --&gt; B[\&quot;Instanciar Game e Player\&quot;]\n    B --&gt; C[\&quot;Define o Detetive Harry\&quot;]\n    C --&gt; D[\&quot;Definir Sala inicial\&quot;]\n    \n    D --&gt; E{\&quot;LOOP DO JOGO\&quot;}\n    \n    E --&gt;|\&quot;Player.prompt\&quot;| F{\&quot;O que o jogador decide fazer?\&quot;}\n\n    %% Caminho de Movimentação\n    F --&gt;|\&quot;Explorar\&quot;| G[\&quot;Selecionar nova Location\&quot;]\n    G --&gt; H{\&quot;A sala esta conectada?\&quot;}\n    H --&gt;|\&quot;Sim\&quot;| I[\&quot;Atualiza current_location\&quot;]\n    H --&gt;|\&quot;Não\&quot;| J[\&quot;Aviso: Caminho bloqueado\&quot;]\n    I --&gt; E\n    J --&gt; E\n\n    %% Caminho de Investigação\n    F --&gt;|\&quot;Investigar\&quot;| K[\&quot;Buscar Evidence na Sala\&quot;]\n    K --&gt; L{\&quot;Nivel atende ao required?\&quot;}\n    L --&gt;|\&quot;Sim\&quot;| M[\&quot;Adiciona ao Inventario\&quot;]\n    L --&gt;|\&quot;Não\&quot;| N[\&quot;Aviso: Falta habilidade\&quot;]\n    M --&gt; O[\&quot;Evidence.read Revela pista\&quot;]\n    O --&gt; E\n    N --&gt; E\n\n    %% Caminho de Diálogo\n    F --&gt;|\&quot;Conversar\&quot;| P[\&quot;Selecionar NPC na Sala\&quot;]\n    P --&gt; Q[\&quot;NPC.talk Retorna dicas\&quot;]\n    Q --&gt; E\n\n    %% Caminho de Evolução / Dano\n    F --&gt;|\&quot;Treinar ou Dano\&quot;| R{\&quot;Evento da Sala\&quot;}\n    R --&gt;|\&quot;Ganhar XP\&quot;| S[\&quot;Ability.increment\&quot;]\n    R --&gt;|\&quot;Armadilha\&quot;| T[\&quot;Character.take_damage\&quot;]\n    \n    S --&gt; E\n    T --&gt; U{\&quot;Vida maior que zero?\&quot;}\n    U --&gt;|\&quot;Sim\&quot;| E\n    U --&gt;|\&quot;Não\&quot;| V([\&quot;Fim de Jogo: Derrota\&quot;])\n\n    %% Condição de Vitória\n    M --&gt; W{\&quot;Coletou todas as Evidencias?\&quot;}\n    W --&gt;|\&quot;Sim\&quot;| X([\&quot;Fim de Jogo: Misterio Resolvido\&quot;])\n    W --&gt;|\&quot;Não\&quot;| O\n\n    %% Aplicando os estilos separadamente\n    class A,V,X inicioFim\n    class E estado\n    class B,C,D,G,I,J,K,M,N,O,P,Q,S,T acao\n    class F,H,L,R,U,W decisao&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="gdxg5eg_WHAHM7AXgAJ6-1">
